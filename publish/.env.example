SUI_NETWORK=testnet
SUI_FULLNODE_URL=https://mysten-rpc.testnet.sui.io:443
# Required for `pnpm run deploy`: Ed25519 secret key (base64 or bech32) for a funded account.
ADMIN_SECRET_KEY=
# Required for `pnpm run deploy-bytes`: address only — the actual signature comes from a multi-sig / KMS.
ADMIN_ADDRESS=
# Path to the Move package, relative to publish/.
MOVE_PACKAGE_PATH=../move/echo
