# publish/.env.mainnet — Echo Move package publish config for SUI MAINNET.
# Copy this to `publish/.env.mainnet`, fill ADMIN_SECRET_KEY, then run:
#   cd publish && env-cmd -f .env.mainnet pnpm deploy
#
# .env.mainnet is committable per CLAUDE.md, but ADMIN_SECRET_KEY is a
# real secret — keep the filled file in your local checkout only and
# never push it. The .example template here stays committed with the
# secret field blank.

SUI_NETWORK=mainnet
SUI_FULLNODE_URL=https://fullnode.mainnet.sui.io:443

# Ed25519 secret key for the funded mainnet account. Export from sui CLI:
#   sui keytool export --key-identity 0x010030a0afc40b6d8fe99cee368cab5652baa0d36b7be60a9b017d5228c0bdfd
# Use the `suiPrivateKey` (bech32) value. The publish script accepts
# both base64 and bech32 forms.
ADMIN_SECRET_KEY=

# Address only — for `pnpm run deploy-bytes` (multi-sig / KMS path).
# Same as `sui client active-address` after `sui client switch --env mainnet`.
ADMIN_ADDRESS=0x010030a0afc40b6d8fe99cee368cab5652baa0d36b7be60a9b017d5228c0bdfd

# Path to the Move package, relative to publish/.
MOVE_PACKAGE_PATH=../move/echo

# Target address for transferDemoCaps.ts (post-publish helper).
# Defaults to the same admin address so caps stay with the deploying
# wallet; override if you want the demo-admin server to manage them.
DEMO_ADMIN_ADDRESS=0x010030a0afc40b6d8fe99cee368cab5652baa0d36b7be60a9b017d5228c0bdfd
