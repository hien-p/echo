# Echo dapp — Sui MAINNET configuration.
# Loaded via `env-cmd -f .env.mainnet ...`. Do not put SECRETS here —
# .env.mainnet is committable per CLAUDE.md, .env / .env.local are not.
# Fill MAINNET-only secrets in .env.local (which IS gitignored).

# Sui mainnet
NEXT_PUBLIC_SUI_NETWORK="mainnet"
NEXT_PUBLIC_SUI_FULLNODE_URL="https://fullnode.mainnet.sui.io:443"

# Walrus mainnet
NEXT_PUBLIC_WALRUS_NETWORK="mainnet"

# Echo Move package ID — populate AFTER publishing to mainnet via:
#   cd publish && env-cmd -f .env.mainnet pnpm deploy
# The publish script writes publish/data/publish.json. Copy the
# `packageId` field here.
NEXT_PUBLIC_ECHO_PACKAGE_ID=""

# Seal key servers on Sui mainnet. Canonical object IDs are published
# in the Mysten Seal docs:
#   https://docs.mystenlabs.com/seal
# Replace the two placeholder objectIds with the live mainnet servers
# before deploying. Format mirrors testnet exactly: an array of
# {objectId, weight} entries.
NEXT_PUBLIC_SEAL_KEY_SERVERS='[]'

# Enoki — needs a SEPARATE app/client created in the Enoki dashboard
# for the mainnet network. The public key is safe to commit here; the
# matching ENOKI_PRIVATE_KEY belongs in .env.local on the deploy host
# (Cloudflare Pages env, or Walrus build env).
NEXT_PUBLIC_ENOKI_PUBLIC_KEY=""

# Google OAuth — same client id used for Enoki zkLogin. The Authorized
# redirect URIs list MUST include the production origin (your Walrus
# Sites portal URL + the Cloudflare Pages origin if you're delegating
# /api calls there).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Demo admin address — the sui-client active address that controls
# FormOwnerCaps for any forms published from the publish/ scripts.
# Pulled from the user's current `sui client active-address` per the
# deploy ask.
NEXT_PUBLIC_DEMO_ADMIN_ADDRESS="0x010030a0afc40b6d8fe99cee368cab5652baa0d36b7be60a9b017d5228c0bdfd"

# Optional: if you deploy the SPA to Walrus Sites but keep the /api
# routes on Cloudflare Pages, point them here. The build-walrus.sh
# parks /api at build time, so the static SPA needs to call the live
# Cloudflare origin for AI/RAG/Walrus-publisher endpoints.
NEXT_PUBLIC_API_BASE_URL="https://staging.echo-20u.pages.dev"

# === Server-only (NOT prefixed NEXT_PUBLIC_) ===
# These are read at build time by API routes — but Walrus Sites is
# static-only and api/ is parked, so they don't ship to the SPA. They
# remain here for the Cloudflare Pages deploy of the same branch.
MEMWAL_SERVER_URL="https://relayer.memwal.ai"
OPENROUTER_MODEL="openai/gpt-4o-mini"

# SECRETS (DO NOT COMMIT — fill in .env.local on each deploy host):
# MEMWAL_PRIVATE_KEY=
# MEMWAL_ACCOUNT_ID=
# OPENROUTER_API_KEY=
# ENOKI_PRIVATE_KEY=
# DEMO_ADMIN_SECRET_KEY=
