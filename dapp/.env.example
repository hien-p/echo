NEXT_PUBLIC_SUI_NETWORK="testnet"
NEXT_PUBLIC_SUI_FULLNODE_URL="https://mysten-rpc.testnet.sui.io:443"
NEXT_PUBLIC_ENOKI_PUBLIC_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# Echo Move package — set after `pnpm run deploy` from publish/.
NEXT_PUBLIC_ECHO_PACKAGE_ID=""
# Walrus + Seal target network. Must align with NEXT_PUBLIC_SUI_NETWORK.
NEXT_PUBLIC_WALRUS_NETWORK="testnet"
# Optional — enable Seal encryption for non-Public tiers. JSON-encoded array
# of {"objectId":"0x...","weight":1}. Leave empty to upload plaintext.
NEXT_PUBLIC_SEAL_KEY_SERVERS=""

# Server-only — Memwal credentials + AI provider for /api/insights.
# Memwal: see https://relayer.dev.memwal.ai docs for delegate-key + accountId.
MEMWAL_PRIVATE_KEY=""
MEMWAL_ACCOUNT_ID=""
MEMWAL_SERVER_URL="https://relayer.dev.memwal.ai"
# OpenRouter API key (any model — default is anthropic/claude-3.5-sonnet).
OPENROUTER_API_KEY=""
# Override the default model id if you want a different one.
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
