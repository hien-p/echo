NEXT_PUBLIC_SUI_NETWORK="testnet"
NEXT_PUBLIC_SUI_FULLNODE_URL="https://mysten-rpc.testnet.sui.io:443"
NEXT_PUBLIC_ENOKI_PUBLIC_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# Echo Move package — set after `pnpm run deploy` from publish/.
NEXT_PUBLIC_ECHO_PACKAGE_ID=""
# Walrus + Seal target network. Must align with NEXT_PUBLIC_SUI_NETWORK.
NEXT_PUBLIC_WALRUS_NETWORK="testnet"
# Enable Seal encryption for non-Public tiers. JSON-encoded array of
# {"objectId":"0x...","weight":1}. Leave empty to upload plaintext.
# Defaults below = Mysten Labs' allowlisted Testnet `Open` servers (no auth,
# rate-limited). For mainnet or permissioned setups see:
# https://github.com/MystenLabs/seal/blob/main/docs/content/Pricing.mdx
NEXT_PUBLIC_SEAL_KEY_SERVERS='[{"objectId":"0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75","weight":1},{"objectId":"0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8","weight":1}]'

# Server-only — Memwal credentials + AI provider for /api/insights.
# Memwal: see https://relayer.dev.memwal.ai docs for delegate-key + accountId.
MEMWAL_PRIVATE_KEY=""
MEMWAL_ACCOUNT_ID=""
MEMWAL_SERVER_URL="https://relayer.dev.memwal.ai"
# OpenRouter API key (any model — default is anthropic/claude-3.5-sonnet).
OPENROUTER_API_KEY=""
# Override the default model id if you want a different one.
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# Demo admin mode. Optional — when both are set, a "Demo admin" pill appears
# in the header. Toggling it on routes form admin reads through the server,
# which signs Seal SessionKey using DEMO_ADMIN_SECRET_KEY (base64 Ed25519,
# matches publish/.env's ADMIN_SECRET_KEY format). Only forms whose owner ==
# NEXT_PUBLIC_DEMO_ADMIN_ADDRESS are eligible. Server holds long-lived
# decrypt capability for these caps — demo only, never for real AdminOnly
# tiers users actually rely on.
NEXT_PUBLIC_DEMO_ADMIN_ADDRESS=""
DEMO_ADMIN_SECRET_KEY=""
