{
  "name": "dapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3333",
    "dev:production": "env-cmd -f .env.production next dev --port 3333",
    "dev:preview": "env-cmd -f .env.preview next dev --port 3333",
    "build": "next build",
    "build:production": "env-cmd -f .env.production next build",
    "build:preview": "env-cmd -f .env.preview next build",
    "build:cf": "next-on-pages",
    "build:walrus": "bash scripts/build-walrus.sh",
    "preview:cf": "wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "deploy:cf": "wrangler pages deploy .vercel/output/static --project-name echo --commit-dirty=true",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "sui-ts-codegen generate",
    "lint": "eslint"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mysten-incubation/memwal": "^0.0.2",
    "@mysten/dapp-kit-core": "^1.2.0",
    "@mysten/dapp-kit-react": "^2.0.1",
    "@mysten/enoki": "^1.0.4",
    "@mysten/seal": "1.1.1",
    "@mysten/sui": "^2.16.0",
    "@mysten/walrus": "1.1.4",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.90.12",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "env-cmd": "^11.0.0",
    "lucide-react": "^0.561.0",
    "motion": "^12.38.0",
    "next": "15.5.2",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "postcss": "^8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.32.0",
    "tailwind-merge": "^3.3.1",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "1.13.16",
    "@cloudflare/workers-types": "^4.20251101.0",
    "@eslint/eslintrc": "^3",
    "@mysten/codegen": "^0.8.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "19.2.11",
    "@types/react-dom": "19.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@types/three": "^0.184.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "15.5.2",
    "jsdom": "^27.3.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vercel": "47.0.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.16",
    "wrangler": "^4.42.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.11",
      "@types/react-dom": "19.2.3"
    }
  }
}
