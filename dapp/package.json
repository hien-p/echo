{
  "name": "dapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:production": "env-cmd -f .env.production next dev",
    "dev:preview": "env-cmd -f .env.preview next dev",
    "build": "next build --turbopack",
    "build:production": "env-cmd -f .env.production next build",
    "build:preview": "env-cmd -f .env.preview next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "sui-ts-codegen generate",
    "lint": "eslint"
  },
  "dependencies": {
    "@mysten/dapp-kit-core": "^1.2.0",
    "@mysten/dapp-kit-react": "^2.0.1",
    "@mysten/enoki": "^1.0.4",
    "@mysten/sui": "^2.9.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "env-cmd": "^11.0.0",
    "lucide-react": "^0.561.0",
    "next": "16.1.6",
    "postcss": "^8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.32.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@mysten/codegen": "^0.8.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "19.2.11",
    "@types/react-dom": "19.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.3.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.11",
      "@types/react-dom": "19.2.3"
    }
  }
}
